---
const waDevis = "https://wa.me/22644608789?text=Bonjour%20Nour%20!%20Je%20voudrais%20obtenir%20un%20devis%20gratuit%20pour%20mon%20commerce%20%C3%A0%20Ouaga.%20Pouvez-vous%20m'aider%20%3F";
---
<section id="hero">
  <div class="container">
    <div class="hero-content">
      <div class="hero-text">
        <div class="hero-badge anim d1">
          <span class="dot"></span>
          Sites web · Ouagadougou
        </div>
        <h1 class="hero-h1 anim d2">Vos futurs clients vous cherchent <span class="hl">sur Google.</span><br>Soyez là où ils regardent.</h1>
        <p class="hero-sub anim d3">Je crée des sites rapides qui apparaissent sur <strong>Google</strong> et convertissent vos visiteurs en clients — directement sur <strong>WhatsApp</strong>.</p>
        <div class="hero-btns anim d4">
          <a href={waDevis} class="btn btn-navy" target="_blank" rel="noopener">
            <svg class="wa-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
            Obtenir mon devis gratuit
          </a>
          <a href="#realisations" class="btn btn-outline">Voir mes exemples →</a>
        </div>
        <div class="hero-stats anim d5">
          <div><div class="hs-num">7–30 j</div><div class="hs-label">délai garanti</div></div>
          <div class="hs-sep"></div>
          <div><div class="hs-num">&lt; 2h</div><div class="hs-label">réponse WhatsApp</div></div>
          <div class="hs-sep"></div>
          <div><div class="hs-num">100%</div><div class="hs-label">le site vous appartient</div></div>
        </div>
      </div>
      <div class="hero-photo-wrap anim d3">
        <div class="hero-photo">
          <img src="/img/founder.png" alt="Nour-Al-Dine OUEDRAOGO, fondateur de Nour Digital" loading="eager" width="460" height="575">
        </div>
        <div class="hero-photo-badge">Nour-Al-Dine · Fondateur</div>
      </div>
    </div>
  </div>
</section>

<style>
#hero {
  position:relative; padding:148px 0 96px; overflow:hidden;
  background:linear-gradient(175deg, #f4f7fc 0%, #ffffff 62%);
}
#hero::before {
  content:''; position:absolute; inset:0; z-index:0;
  background-image:
    linear-gradient(rgba(15,45,110,0.022) 1px, transparent 1px),
    linear-gradient(90deg, rgba(15,45,110,0.022) 1px, transparent 1px);
  background-size:56px 56px;
  -webkit-mask-image:linear-gradient(180deg,#000 0%,transparent 72%);
          mask-image:linear-gradient(180deg,#000 0%,transparent 72%);
}
#hero::after {
  content:''; position:absolute; top:24%; right:5%;
  width:520px; height:440px;
  background:radial-gradient(ellipse, rgba(249,115,22,0.08) 0%, transparent 66%);
  pointer-events:none; z-index:0;
}
.hero-content {
  position:relative; z-index:1; width:100%;
  display:grid; grid-template-columns:1.06fr 0.94fr; gap:56px;
  align-items:center; text-align:left;
}
.hero-badge {
  display:inline-flex; align-items:center; gap:8px;
  font-size:11px; font-weight:600; letter-spacing:0.13em; text-transform:uppercase;
  color:var(--orange); background:var(--orange-dim); border:1px solid var(--orange-border);
  padding:8px 16px; border-radius:100px; margin-bottom:24px;
}
.hero-badge .dot { width:6px; height:6px; background:var(--orange); border-radius:50%; animation:pulse 2s ease-in-out infinite; }
.hero-h1 { margin-bottom:20px; color:var(--text); font-size:clamp(32px,3.7vw,48px); line-height:1.08; }
.hero-h1 .hl { color:var(--orange); white-space:nowrap; background:linear-gradient(rgba(249,115,22,0.16),rgba(249,115,22,0.16)) 0 86%/100% 0.18em no-repeat; }
.hero-sub { font-size:clamp(15px,1.5vw,18px); color:var(--text2); max-width:500px; margin:0 0 32px; line-height:1.65; }
.hero-sub strong { color:var(--navy); font-weight:700; }
.hero-btns { display:flex; gap:14px; justify-content:flex-start; flex-wrap:wrap; margin-bottom:28px; }
.hero-stats { display:flex; align-items:center; gap:22px; margin-top:30px; padding-top:24px; border-top:1px solid #eef2f7; flex-wrap:wrap; }
.hs-num { font-size:22px; font-weight:800; color:var(--navy); letter-spacing:-0.01em; }
.hs-label { font-size:12px; color:var(--text3); margin-top:2px; font-weight:500; }
.hs-sep { width:1px; height:34px; background:var(--border); }

.hero-photo-wrap { position:relative; max-width:460px; margin-left:auto; }
.hero-photo { border-radius:24px; overflow:hidden; aspect-ratio:4/5; box-shadow:0 22px 54px rgba(15,45,110,0.18); border:1px solid #eef2f7; }
.hero-photo img { width:100%; height:100%; object-fit:cover; object-position:50% 16%; display:block; }
.hero-photo-badge {
  position:absolute; bottom:-14px; left:-14px;
  background:var(--orange); color:#fff;
  font-size:12px; font-weight:700; letter-spacing:0.08em; text-transform:uppercase;
  padding:11px 18px; border-radius:13px; box-shadow:0 8px 22px rgba(249,115,22,0.35);
}

@media (max-width:900px) {
  .hero-content { grid-template-columns:1fr; gap:38px; }
  .hero-photo-wrap { max-width:340px; margin:0; order:2; }
  .hero-sub { max-width:none; }
}
@media (max-width:640px) {
  .hero-stats { gap:16px; margin-top:26px; padding-top:20px; }
  .hs-num { font-size:19px; }
  .hs-sep { height:28px; }
  .hero-badge { border-radius:12px; font-size:9px; padding:7px 12px; }
}
@media (max-width:480px) {
  .hero-btns .btn { font-size:14px; padding:13px 20px; }
  #hero { padding:120px 0 72px; }
}
@media (max-width:400px) {
  .hero-btns { flex-direction:column; align-items:center; }
}
</style>
