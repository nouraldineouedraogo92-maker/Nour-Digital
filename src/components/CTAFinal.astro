---
const wa = "https://wa.me/22644608789?text=Bonjour%20Nour%20!%20Je%20voudrais%20d%C3%A9marrer%20une%20discussion%20gratuite%20pour%20la%20cr%C3%A9ation%20de%20mon%20site%20web%20%C3%A0%20Ouaga.";
---
<section id="cta-final" style="padding:80px 0; background:var(--bg);">
  <div class="container">
    <div class="cta-card anim">
      <div class="label">On démarre ?</div>
      <h2>Prêt à avoir un site qui fait<br><span style="color:var(--orange);">rentrer de vrais clients ?</span></h2>
      <p class="cta-sub">Un seul message suffit pour commencer. Voici exactement ce qui se passe après :</p>
      <div class="cta-what-happens">
        Vous m'écrivez sur WhatsApp → <strong>Je vous réponds sous 2 heures</strong> → On discute de votre commerce en quelques minutes → <strong>Je vous donne un premier avis gratuit</strong> sur ce qu'un site peut apporter à votre activité. Aucun engagement.
      </div>
      <a href={wa} class="btn btn-wa" target="_blank" rel="noopener">
        <svg class="wa-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
        Démarrer la discussion gratuite
      </a>
      <div class="cta-trust">
        <span><span class="ck">✓</span> Gratuit & sans engagement</span>
        <span><span class="ck">✓</span> Réponse sous 2 heures</span>
        <span><span class="ck">✓</span> Aucune pression</span>
      </div>
    </div>
  </div>
</section>

<style>
.cta-card {
  background:var(--navy); border-radius:24px; padding:72px 48px; text-align:center;
  position:relative; overflow:hidden;
}
.cta-card::before {
  content:''; position:absolute; top:0; right:0; width:400px; height:400px;
  background:radial-gradient(ellipse at top right, rgba(249,115,22,0.2) 0%, transparent 60%);
  pointer-events:none;
}
.cta-card::after {
  content:''; position:absolute; bottom:0; left:0; width:300px; height:250px;
  background:radial-gradient(ellipse at bottom left, rgba(249,115,22,0.1) 0%, transparent 60%);
  pointer-events:none;
}
.cta-card .label { background:rgba(249,115,22,0.15); border-color:rgba(249,115,22,0.3); color:var(--orange); position:relative; z-index:1; }
.cta-card h2 { color:#fff; max-width:660px; margin:0 auto 14px; position:relative; z-index:1; }
.cta-sub { color:rgba(255,255,255,0.65); font-size:16px; margin-bottom:10px; position:relative; z-index:1; max-width:580px; margin-left:auto; margin-right:auto; }
.cta-what-happens {
  font-size:13px; color:rgba(255,255,255,0.5);
  background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.1);
  border-radius:10px; padding:12px 20px; display:inline-block;
  margin-bottom:32px; position:relative; z-index:1; line-height:1.6;
}
.cta-what-happens strong { color:rgba(255,255,255,0.8); }
.cta-card .btn { position:relative; z-index:1; font-size:16px; padding:16px 32px; }
.cta-trust { display:flex; gap:24px; justify-content:center; flex-wrap:wrap; margin-top:24px; position:relative; z-index:1; font-size:13px; color:rgba(255,255,255,0.45); }
.cta-trust span { display:flex; align-items:center; gap:6px; }
.cta-trust .ck { color:var(--orange); }

@media (max-width:640px) {
  .cta-card { padding:48px 24px; }
  .cta-card .btn { width:100%; justify-content:center; white-space:normal; text-align:center; }
}
@media (max-width:480px) { .cta-card { padding:40px 20px; } }
</style>
