---
<footer>
  <div class="container">
    <div class="footer-grid">
      <div>
        <a href="#" class="footer-logo">
          <span class="n1">Nour Digital</span>
          <span class="n2">Sites web · Ouagadougou</span>
        </a>
        <p class="footer-desc">Je crée des sites web pour les restaurants de Ouagadougou — des sites simples, rapides et pensés pour attirer de vrais clients.</p>
        <a href={waContact} class="btn btn-wa" target="_blank" rel="noopener" style="font-size:13px;padding:11px 20px;">
          <Fragment set:html={WA_SVG}/>
          Me contacter
        </a>
      </div>
      <div class="footer-nav">
        <h4>Navigation</h4>
        <ul>
          <li><a href="#solutions">Notre approche</a></li>
          <li><a href="#process">Comment ça marche</a></li>
          <li><a href="#realisations">Exemples de travaux</a></li>
          <li><a href="#pricing">Tarifs</a></li>
          <li><a href="#about">À propos</a></li>
          <li><a href="#faq">FAQ</a></li>
        </ul>
      </div>
      <div class="footer-contact">
        <h4>Devis gratuit</h4>
        <div class="footer-audit-card">
          <p>Vous avez un projet ou une question ? <strong>Écrivez-moi sur WhatsApp</strong> — je vous réponds sous 2 heures, sans pression et sans script de vente.</p>
          <a href={waDevis} class="btn btn-wa" target="_blank" rel="noopener" style="font-size:13px;width:100%;justify-content:center;">
            <Fragment set:html={WA_SVG}/>
            Demander un devis gratuit
          </a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© 2026 Nour Digital · Ouagadougou, Burkina Faso</span>
      <span style="display:flex;gap:16px;"></span>
    </div>
  </div>
</footer>

<style>
footer { background:var(--navy); border-top:1px solid rgba(255,255,255,0.08); padding:64px 0 32px; }
.footer-grid { display:grid; grid-template-columns:2fr 1fr 1.4fr; gap:48px; margin-bottom:48px; }
.footer-logo { display:inline-flex; flex-direction:column; line-height:1.1; text-decoration:none; margin-bottom:14px; }
.footer-logo .n1 { font-size:22px; font-weight:800; color:#fff; }
.footer-logo .n2 { font-size:8px; font-weight:700; letter-spacing:0.2em; text-transform:uppercase; color:var(--orange); }
.footer-desc { font-size:14px; color:rgba(255,255,255,0.5); line-height:1.7; margin-bottom:20px; max-width:290px; }
.footer-nav h4 { font-size:10px; font-weight:700; letter-spacing:0.2em; text-transform:uppercase; color:rgba(255,255,255,0.35); margin-bottom:14px; }
.footer-nav ul { list-style:none; display:flex; flex-direction:column; gap:9px; }
.footer-nav ul a { font-size:14px; color:rgba(255,255,255,0.55); text-decoration:none; transition:color 0.2s; }
.footer-nav ul a:hover { color:var(--orange); }
.footer-contact h4 { font-size:10px; font-weight:700; letter-spacing:0.2em; text-transform:uppercase; color:rgba(255,255,255,0.35); margin-bottom:14px; }
.footer-audit-card { background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.1); border-radius:14px; padding:20px; }
.footer-audit-card p { font-size:13px; color:rgba(255,255,255,0.55); margin-bottom:14px; line-height:1.55; }
.footer-audit-card p strong { color:var(--orange); }
.footer-bottom { border-top:1px solid rgba(255,255,255,0.08); padding-top:24px; display:flex; align-items:center; justify-content:space-between; font-size:12px; color:rgba(255,255,255,0.3); flex-wrap:wrap; gap:8px; }

@media (max-width:900px) {
  .footer-grid { grid-template-columns:1fr; gap:32px; }
  .footer-bottom { flex-direction:column; text-align:center; }
  .footer-desc { max-width:100%; }
}
</style>
